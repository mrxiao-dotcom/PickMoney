<Window x:Class="PickMoney.App.StrategySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="策略设置"
        Height="620"
        Width="960"
        MinHeight="520"
        MinWidth="840"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False">
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="策略设置" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="保存并关闭" Command="{Binding SaveCommand}" Margin="0,0,8,0" MinWidth="110" />
                <Button Content="取消" Command="{Binding CancelCommand}" MinWidth="88" />
            </StackPanel>
        </DockPanel>

        <ScrollViewer Grid.Row="1" Margin="0,14,0,14" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="16" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Foreground="#666" Text="触发跌幅(%)" />
                            <TextBox Text="{Binding TriggerDropPercent, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Foreground="#666" Text="止盈倍数" />
                            <TextBox Text="{Binding TakeProfitMultiplier, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Foreground="#666" Text="扫描间隔(秒)" />
                            <TextBox Text="{Binding ScanIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Margin="0,14,0,0" Padding="16" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="飞书推送" />
                        <TextBlock Margin="0,8,0,0" Foreground="#666" Text="Webhook 地址（每行一个，支持多个）" />
                        <TextBox Height="120"
                                 Margin="0,8,0,0"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 Text="{Binding FeishuWebhooks, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Margin="0,14,0,0" Padding="16" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="手工导入" />
                        <TextBlock Margin="0,8,0,0" Foreground="#666" Text="品种代码（逗号、分号、换行均可分隔）" />
                        <TextBox Height="100"
                                 Margin="0,8,0,0"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 Text="{Binding ManualSymbolsInput, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <TextBlock Grid.Row="2" Foreground="#666" Text="提示：保存后会立即更新主窗口中的策略摘要，并持久化到本地配置文件。" />
    </Grid>
</Window>
